# Admin dashboard configuration
# Copy this file to .env.local and fill in your own values.
# These are also set in Vercel's project settings for production.

# Password that gates the /admin login screen.
ADMIN_PASSWORD=

# GitHub personal access token with permission to commit to your repo.
GITHUB_TOKEN=

# Target repo in "owner/name" form, e.g. astromarb/narwhal-blog
GITHUB_REPO=

# Branch that admin commits are pushed to (e.g. main).
GITHUB_BRANCH=main
